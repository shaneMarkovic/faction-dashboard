{
  "name": "@torn/collector",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "proof": "tsx --env-file=../../.env.local src/proof.ts",
    "dev": "tsx watch --env-file=../../.env.local src/index.ts",
    "start": "tsx src/index.ts",
    "migrate": "tsx --env-file=../../.env.local src/db/migrate.ts",
    "migrate:prod": "tsx src/db/migrate.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@torn/shared": "workspace:*",
    "pg": "^8.21.0",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.20.0",
    "typescript": "^5.7.2"
  }
}

# Torn Faction Dashboard — environment template.
# Copy to .env.local and fill in. NEVER commit .env.local (see .gitignore).

# --- Torn API keys (multi-faction) -----------------------------------------
# Any number of keys. The collector probes each with /key/info and groups them
# into per-faction pools automatically — adding a faction is just adding a key.
# Naming: TORN_API_KEY (single/legacy) or TORN_KEY_<LABEL>.
TORN_API_KEY=
# TORN_KEY_MAIN=
# TORN_KEY_FEEDER=
# How often (ms) the collector re-scans env + DB keys to pick up keys submitted
# via the dashboard without a restart. Default 60000. Set 0 to scan once.
# KEY_RECONCILE_MS=60000

# --- Supabase (DB + Auth + Realtime) ---------------------------------------
# From your Supabase project: Settings → API and Settings → Database.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=   # collector + server-only; bypasses RLS. Never ship to client.
DATABASE_URL=                # postgres connection string for migrations

# --- Discord ----------------------------------------------------------------
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=
DISCORD_PUBLIC_KEY=          # for verifying interactions webhook signatures

# --- App secrets ------------------------------------------------------------
KEY_ENCRYPTION_KEY=          # 32-byte base64 — AES-256-GCM key for encrypting Torn keys at rest
INGEST_HMAC_SECRET=          # signs/verifies userscript ingest tokens
